generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id       String @id
  name     String
  role     String
  title    String
  email    String @unique
  phone    String
  status   String
  since    String
  password String @default("")

  managedProjects   Project[]     @relation("ProjectPM")
  foremanProjects   Project[]     @relation("ProjectForeman")
  teamMemberships   ProjectTeam[]
  assignedTasks     Task[]
  reportedIncidents Incident[]
  ownedDocuments    Doc[]
  assignedCards     Card[]
  cardComments      CardComment[]
  activityLogs      Activity[]
  authoredArticles  Article[]
  passwordResets    PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Client {
  id       String    @id
  name     String
  sector   String
  contact  String
  email    String
  phone    String
  since    String
  projects Project[]
}

model Project {
  id             String @id
  name           String
  location       String @default("")
  category       String @default("")
  type           String @default("")
  dateCompleted  String @default("")
  owner          String @default("")
  architect      String @default("")
  constructionType String @default("")
  contractType   String @default("")
  value          Float  @default(0)
  grossFloorArea String @default("")
  description    String @default("")

  // Kept for internal features (board, tasks, incidents) — not shown in form
  clientId  String?
  sector    String  @default("")
  status    String  @default("Active")
  progress  Int     @default(0)
  budget    Float   @default(0)
  spent     Float   @default(0)
  start     String  @default("")
  end       String  @default("")
  pmId      String?
  foremanId String?

  client     Client?       @relation(fields: [clientId], references: [id])
  pm         User?         @relation("ProjectPM", fields: [pmId], references: [id])
  foreman    User?         @relation("ProjectForeman", fields: [foremanId], references: [id])
  team       ProjectTeam[]
  milestones Milestone[]
  tasks      Task[]
  incidents  Incident[]
  docs       Doc[]
  cards      Card[]
  activities Activity[]
  articles   Article[]
  photos     ProjectPhoto[]
}

model ProjectPhoto {
  id        Int     @id @default(autoincrement())
  projectId String
  path      String
  order     Int     @default(0)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectTeam {
  projectId String
  userId    String
  project   Project @relation(fields: [projectId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@id([projectId, userId])
}

model Milestone {
  id        Int     @id @default(autoincrement())
  projectId String
  n         String
  d         String
  done      Boolean @default(false)
  project   Project @relation(fields: [projectId], references: [id])
}

model Task {
  id         String  @id
  title      String
  projectId  String
  assigneeId String
  due        String
  status     String
  priority   String
  project    Project @relation(fields: [projectId], references: [id])
  assignee   User    @relation(fields: [assigneeId], references: [id])
}

model Incident {
  id           String  @id
  projectId    String
  date         String
  type         String
  severity     String
  status       String
  reportedById String
  note         String
  project      Project @relation(fields: [projectId], references: [id])
  reportedBy   User    @relation(fields: [reportedById], references: [id])
}

model Doc {
  id        String   @id
  name      String
  type      String
  projectId String?
  size      String
  updated   String
  ownerId   String
  path      String   @default("")
  project   Project? @relation(fields: [projectId], references: [id])
  owner     User     @relation(fields: [ownerId], references: [id])
}

model Tender {
  id           String  @id
  ref          String
  title        String
  org          String
  platform     String
  type         String
  category     String
  value        Float
  province     String
  city         String
  published    String
  closing      String
  status       String
  tracked      Boolean @default(false)
  address      String  @default("")
  postalCode   String  @default("")
  bidUrl       String  @default("") // external bid-room / plan-room link (e.g. SmartBid)
  contactName  String
  contactEmail String
  contactPhone String
  contactFax   String  @default("")
  codes        String  @default("[]") // JSON array of "code - description" strings (CSI divisions needed)
  note         String?
  desc         String
}

model Card {
  id         String        @id
  title      String
  col        String
  projectId  String
  assigneeId String
  priority   String
  due        String
  project    Project       @relation(fields: [projectId], references: [id])
  assignee   User          @relation(fields: [assigneeId], references: [id])
  subtasks   CardSubtask[]
  comments   CardComment[]
}

model CardSubtask {
  id     Int     @id @default(autoincrement())
  cardId String
  t      String
  done   Boolean @default(false)
  card   Card    @relation(fields: [cardId], references: [id])
}

model CardComment {
  id     Int    @id @default(autoincrement())
  cardId String
  who    String
  when   String
  text   String
  card   Card   @relation(fields: [cardId], references: [id])
  user   User   @relation(fields: [who], references: [id])
}

model Activity {
  id        Int      @id @default(autoincrement())
  who       String
  what      String
  createdAt DateTime @default(now())
  projectId String?
  user      User     @relation(fields: [who], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])
}

model Setting {
  key   String @id
  value String
}

model HeroImage {
  id    Int    @id @default(autoincrement())
  path  String
  order Int    @default(0)
}

model JobPosting {
  id           String   @id
  createdAt    DateTime @default(now())
  title        String
  department   String   @default("")
  location     String   @default("Toronto, ON")
  type         String   @default("Full-time")
  description  String   @default("")
  requirements String   @default("")
  status       String   @default("Draft")
}

model TeamMember {
  id    String @id
  order Int    @default(0)
  name  String
  title String
  bio   String @default("")
  photo String @default("")
}

model ContactInquiry {
  id        String   @id
  createdAt DateTime @default(now())
  name      String
  email     String
  company   String   @default("")
  message   String
  read      Boolean  @default(false)
}

model Article {
  id        String   @id
  title     String
  slug      String   @unique
  projectId String?
  authorId  String
  status    String
  date      String
  tags      String
  featured  Boolean  @default(false)
  excerpt   String
  body         String   @default("")
  coverImage   String   @default("")
  linkedinPost String   @default("")
  instagramPost String  @default("")
  words       Int
  project   Project? @relation(fields: [projectId], references: [id])
  author    User     @relation(fields: [authorId], references: [id])
}
